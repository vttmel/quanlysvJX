# Đường dẫn gốc của project, dùng để Manager API điều khiển docker compose của apps/jx-services
# - Linux: có thể bỏ trống, lệnh `MANAGER_PROJECT_ROOT=$PWD docker compose up -d --build` sẽ tự điền.
# - Windows (Docker Desktop): PHẢI điền theo định dạng mount nội bộ của Docker Desktop, không dùng
#   đường dẫn kiểu C:\... vì API container gọi `docker compose` ra Docker daemon trên host.
#   Định dạng: /run/desktop/mnt/host/<ổ đĩa viết thường>/<đường dẫn dùng dấu />
#   Ví dụ project ở "C:\Users\Admin\Documents\GitHub\quanlysvJX" thì điền:
#   MANAGER_PROJECT_ROOT=/run/desktop/mnt/host/c/Users/Admin/Documents/GitHub/quanlysvJX
MANAGER_PROJECT_ROOT=/run/desktop/mnt/host/c/Users/Admin/Documents/GitHub/quanlysvJX
# Đường dẫn phiên bản game
SERVER_PATH=./versions/jxmel01/jxser

# IP các service JX
JX_IP=192.168.1.11
JX_MYSQL_IP=127.0.0.1
JX_PAYSYS_IP=127.0.0.1
JX_MSSQL_IP=127.0.0.1

# Database cho docker compose JX
JX_MYSQL_ROOT_PASSWORD=1234560123
JX_MSSQL_SA_PASSWORD=SAJx123456
JX_MSSQL_ACCOUNT_DATABASE=account_tong

# MSSQL mã hóa cho paysys/s3relay
JX_MSSQL_IP_ENCRYPTED=s70D313SITWM_>0UlFGGNTHBkVAAWWMA
JX_MSSQL_DB_ENCRYPTED=q0n8oitJqQQsfARc__0UCLAbwKw1FwNH
JX_MSSQL_USER_ENCRYPTED=q5wdvorvzRYp5dfxjDEjLRylzTRh9vpY
JX_MSSQL_PASS_ENCRYPTED=Zn0A_X0BcQBettvBSfzG5vXiBfwJXihZ

# Tài khoản MSSQL plaintext cho API quản lý
MSSQL_USER=sa
MSSQL_PASSWORD=SAJx123456
MSSQL_DATABASE=account_tong

BACKUP_SCHEDULER_ENABLED=true
