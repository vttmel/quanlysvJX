{
  "name": "ui",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "vitest": "vitest run --passWithNoTests",
    "lint": "npm run oxlint && npm run stylelint",
    "oxlint": "oxlint .",
    "stylelint": "stylelint \"src/**/*.css\" --cache",
    "format:test": "oxfmt --check \"**/*.{ts,tsx,css}\"",
    "format:write": "oxfmt --write \"**/*.{ts,tsx,css}\"",
    "test": "npm run typecheck && npm run format:test && npm run lint && npm run vitest && npm run build"
  },
  "dependencies": {
    "@mantine/core": "latest",
    "@mantine/form": "^9.3.1",
    "@mantine/hooks": "latest",
    "@mantine/notifications": "latest",
    "@tabler/icons-react": "^3.43.0",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.6.0",
    "dayjs": "^1.11.21",
    "mantine-form-zod-resolver": "^1.3.0",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "^7.17.0",
    "vite": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/react": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "latest",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.58.0",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "stylelint": "^17.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "latest",
    "vitest": "latest"
  }
}
